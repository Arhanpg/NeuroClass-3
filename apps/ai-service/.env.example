# NeuroClass AI Service — Environment Variables
# Copy to .env and fill in values for local development.
# In production, these are injected by Cloud Run via Secret Manager.

# --- Supabase ---
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>
SUPABASE_DB_URL=postgresql://postgres:<password>@db.<ref>.supabase.co:5432/postgres

# --- OpenAI ---
OPENAI_API_KEY=sk-...

# --- Google Gemini (free alternative to Claude for supervisor) ---
# Get from: https://aistudio.google.com/app/apikey  (FREE tier available)
GEMINI_API_KEY=AIza...

# --- GitHub ---
GITHUB_TOKEN=ghp_...

# --- LangSmith (optional, for tracing) ---
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=neuroclass
LANGCHAIN_TRACING_V2=true

# --- AI Service Auth ---
# Shared secret between Next.js and this service
AI_SERVICE_SECRET=<random-hex-32-bytes>

# --- Web Search (FREE alternative to Google Cloud) ---
# Using DuckDuckGo (no API key needed) or Serper.dev (free tier: 100 req/month)
# SERPER_API_KEY=<optional>

# --- Notifications (FREE alternative) ---
# Using Resend free tier (3,000 emails/month free)
RESEND_API_KEY=re_...

# --- App ---
PORT=8080
ENVIRONMENT=development
