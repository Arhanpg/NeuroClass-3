# ============================================================
# NeuroClass — Next.js Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to git.
# ============================================================

# --- Supabase (required) ------------------------------------
# Found at: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-secret-key>

# --- AI Service (Phase 3+) ----------------------------------
# Local dev: http://localhost:8080
# Production: your Railway / Cloud Run URL
CLOUD_RUN_URL=http://localhost:8080
AI_SERVICE_SECRET=<generate with: openssl rand -hex 32>

# --- Email (Phase 4) ----------------------------------------
# Resend.com — free 3,000 emails/month
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# --- Search fallback (Phase 3+) -----------------------------
# Serper.dev — free 100 searches/month
# SERPER_API_KEY=<your-serper-key>
