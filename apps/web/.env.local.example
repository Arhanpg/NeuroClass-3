# ============================================================
# NeuroClass — Next.js Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ============================================================

# --- Supabase (Required) ---
# Get these from: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://<your-project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# --- Supabase Service Role (Server-only, NEVER prefix with NEXT_PUBLIC_) ---
# Get from: Supabase Dashboard > Project Settings > API > service_role key
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# --- AI Service (Cloud Run or local Docker) ---
# Production: https://neuroclass-ai-<hash>.run.app
# Local dev:  http://localhost:8080
CLOUD_RUN_URL=http://localhost:8080

# --- AI Service Shared Secret (for request validation) ---
# Generate with: openssl rand -hex 32
AI_SERVICE_SECRET=<generate-a-random-secret>

# --- GitHub Webhook (for /api/webhooks/github) ---
# Set this in your GitHub repo Webhook settings too
GITHUB_WEBHOOK_SECRET=<your-github-webhook-secret>

# --- Next.js ---
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development
